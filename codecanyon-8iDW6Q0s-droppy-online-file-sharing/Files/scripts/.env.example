# Envento migration runner config.
# Copy to scripts/.env (or pass ENV_FILE=/path/to/file) before running migrate.sh.
# Real environment variables always win over values in this file.

# --- Database connection (required) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=droppy

# --- mysql client (optional) ---
# Path to the mysql binary. Leave unset to auto-detect from $PATH or DBngin.
# MYSQL_BIN=/usr/local/mysql/bin/mysql

# --- Fresh-install bootstrap (optional) ---
# 1 (default) = if droppy_settings is missing, import application/install/droppy.sql
# 0           = skip the base-schema import (use when DB is managed externally)
# BOOTSTRAP_BASE=1
