# App
APP_ENV=production
APP_URL=http://your-server-ip

# Server
SERVER_IP=your-server-ip
SERVER_SSH_PORT=22
SERVER_ROOT_PASS=your-ssh-root-password
DROPPY_PATH=/var/www/droppy/

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=droppy
DB_USERNAME=droppy
DB_PASSWORD=your_db_password
DB_ROOT_PASSWORD=your_root_password

# PHP
PHP_VERSION=8.3
